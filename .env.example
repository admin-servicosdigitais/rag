AWS_REGION=us-east-1

# Agente Bedrock
BEDROCK_AGENT_NAME=agente-rag-demo
BEDROCK_AGENT_INSTRUCTION=Use a knowledge base para responder perguntas com base apenas no documento indexado.
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_AGENT_ROLE_ARN=arn:aws:iam::123456789012:role/BedrockAgentRole

# Knowledge Base
BEDROCK_KB_NAME=kb-rag-demo
BEDROCK_KB_DESCRIPTION=Knowledge Base para documento document.txt
BEDROCK_KB_ROLE_ARN=arn:aws:iam::123456789012:role/BedrockKnowledgeBaseRole
BEDROCK_KB_S3_BUCKET_ARN=arn:aws:s3:::meu-bucket
BEDROCK_KB_S3_PREFIX=document.txt

# OpenSearch Serverless (necessário para armazenamento vetorial da KB)
OPENSEARCH_COLLECTION_ARN=arn:aws:aoss:us-east-1:123456789012:collection/abcxyz
OPENSEARCH_VECTOR_INDEX_NAME=bedrock-kb-index
OPENSEARCH_VECTOR_FIELD=bedrock_vector
OPENSEARCH_TEXT_FIELD=bedrock_text
OPENSEARCH_METADATA_FIELD=bedrock_metadata

# Teste RAG
RAG_TEST_QUESTION=Qual é o conteúdo principal do documento?
